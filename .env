# EmailJS credentials — sign up free at https://emailjs.com
#
# SETUP STEPS:
# 1. Connect info@kurios-sat.tech as the Service → paste Service ID below
# 2. Create a template. Set "To Email" field to  {{to_email}}  in the template settings.
#    Template body can use: {{from_name}}, {{reply_to}}, {{message}}, {{to_email}}
# 3. Go to Account → API Keys → copy your Public Key below
#
# The form will always deliver to info@kurios-sat.tech (hidden field).
# The displayed public email info@kurios-sat.tech stays on the page for users to see.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
